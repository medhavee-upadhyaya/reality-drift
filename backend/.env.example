# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Bright Data ────────────────────────────────────────────────────────────────
BRIGHT_DATA_CUSTOMER_ID=hl_xxxxxxxxxx
BRIGHT_DATA_RESIDENTIAL_PASSWORD=your_password_here

# Web Unlocker zone password (same dashboard → Zones → web_unlocker1)
BRIGHT_DATA_WEB_UNLOCKER_PASSWORD=your_web_unlocker_password

# SERP API key (Bright Data dashboard → API token)
BRIGHT_DATA_API_TOKEN=your_api_token_here

# Scraping Browser zone (Zones → scraping_browser)
BRIGHT_DATA_SCRAPING_BROWSER_PASSWORD=your_scraping_browser_password

# ─── Cognee ─────────────────────────────────────────────────────────────────────
# Reuses your Anthropic key — no extra cost
COGNEE_LLM_API_KEY=sk-ant-...
COGNEE_DB_PATH=./cognee_db

# ─── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://reality-drift.vercel.app
